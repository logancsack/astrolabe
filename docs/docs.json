{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Astrolabe Cloud",
  "description": "Hosted AI routing, billing, observability, and stack control for production AI APIs.",
  "colors": {
    "primary": "#0055FF",
    "light": "#4D8DFF",
    "dark": "#0042CC"
  },
  "background": {
    "color": {
      "light": "#F8F9FA"
    }
  },
  "fonts": {
    "family": "Inter",
    "body": {
      "family": "Inter",
      "weight": 400
    },
    "heading": {
      "family": "Geist",
      "weight": 600
    }
  },
  "favicon": "/logo/astrolabe-icon-light.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "how-it-works",
              "hosted-gateway"
            ]
          },
          {
            "group": "Routing stacks",
            "pages": [
              "routing-stacks/concepts",
              "routing-stacks/customization",
              "routing-stacks/request-selection"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "openclaw"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "model-roster",
              "routing-reference",
              "configuration",
              "troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Gateway endpoints",
            "pages": [
              "api-reference/endpoint/responses",
              "api-reference/endpoint/chat-completions"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Astrolabe",
          "href": "https://astrolabe.run",
          "icon": "house"
        },
        {
          "anchor": "Cloud app",
          "href": "https://app.astrolabe.run",
          "icon": "cloud"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@astrolabe.run"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open app",
      "href": "https://app.astrolabe.run"
    }
  },
  "logo": {
    "light": "/logo/astrolabe-horiz-light.png",
    "dark": "/logo/astrolabe-horiz-dark.png"
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "website": "https://astrolabe.run"
    }
  }
}
